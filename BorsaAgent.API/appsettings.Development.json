{
    "Serilog": {
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft.AspNetCore": "Warning",
                "Microsoft.EntityFrameworkCore.Database.Command": "Information"
            }
        },
        "Enrich": [ "FromLogContext", "WithMachineName" ],
        "Properties": {
            "Application": "BorsaAgent"
        },
        "WriteTo": [
            {
                "Name": "Debug",
                "Args": {
                    "restrictedToMinimumLevel": "Information"
                }
            },
            {
                "Name": "Console",
                "Args": {
                    "restrictedToMinimumLevel": "Information"
                }
            }
        ]
    },
    "AllowedHosts": "*",
    "ConnectionStrings": {
        "DefaultConnection": "Host=localhost;Port=5432;Database=BorsaAgentDbV3;Username=borsa_user;Password=borsa_passwd"
    }
}
